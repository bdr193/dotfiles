# qkvps zsh completion — eval-loaded from ~/.zshrc via `eval "$(qkvps --completion)"`
# (mirrors how the qk CLI loads its completion). Dynamic values (session names,
# conversation ids) are fetched from the box over ssh with a short timeout.

_qkvps() {
  local -a actions
  actions=(
    '-l:list tmux sessions'            '--list:list tmux sessions'
    '-c:list Claude conversations'     '--claude:list Claude conversations'
    '-r:resume a Claude conversation'  '--resume:resume a Claude conversation'
    '--kill:kill a tmux session'
    '--clean:show/reap orphaned mosh-servers'
    '--up:bring up dev services (default: all)'
    '--down:stop dev services (default: core + console)'
    '-u:upload file(s) to the box'     '--upload:upload file(s) to the box'
    '-f:with --clean, reap them'       '--force:with --clean, reap them'
    '--json:machine-readable output'
    '-h:help'                          '--help:help'
  )

  # first arg, and it's not a flag -> a session name to attach
  if (( CURRENT == 2 )) && [[ "${words[2]}" != -* ]]; then
    _qkvps_sessions; return
  fi
  # once -u/--upload is on the line, remaining args are local file paths
  if (( ${words[(I)--upload]} || ${words[(I)-u]} )); then
    _files; return
  fi
  # once --up/--down is on the line, remaining args are dev-service names
  if (( ${words[(I)--up]} || ${words[(I)--down]} )); then
    _qkvps_services; return
  fi
  # argument expected by the previous flag
  case "${words[CURRENT-1]}" in
    --kill)      _qkvps_sessions; return ;;
    -r|--resume) _qkvps_ids;      return ;;
  esac
  _describe -t actions 'qkvps action' actions
}

_qkvps_sessions() {
  local -a s
  s=(${(f)"$(ssh -o BatchMode=yes -o ConnectTimeout=4 dev@quidkey-claude \
        'tmux ls -F "#{session_name}" 2>/dev/null')"})
  (( ${#s} )) && _describe -t sessions 'tmux session' s
}

_qkvps_ids() {
  local -a ids
  ids=(${(f)"$(ssh -o BatchMode=yes -o ConnectTimeout=4 dev@quidkey-claude \
        'for f in ~/.claude/projects/*/*.jsonl; do [ -e "$f" ] && basename "$f" .jsonl | cut -c1-8; done 2>/dev/null')"})
  (( ${#ids} )) && _describe -t ids 'claude conversation' ids
}

_qkvps_services() {
  local -a svcs
  svcs=(
    'core:core dev server (:5679)'
    'console:console dev server (:3000)'
    'deps:all backing services (docker)'
    'meili:meilisearch'
    'fake-tm:fake-transfermate'
    'fake-flinks:fake-flinks'
  )
  _describe -t services 'dev service' svcs
}

compdef _qkvps qkvps
