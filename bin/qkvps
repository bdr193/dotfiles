#!/usr/bin/env bash
# qkvps — the CLI for Rabea's Claude-on-VPS (quidkey-claude).
#
# Grammar (GNU-flag style, mirrors the `qk` CLI's conventions): a bare word is
# ALWAYS a tmux session to attach; every ACTION is a --flag. So `qkvps core`
# can only ever mean "attach session core" — no verb/name ambiguity.
#
# Runs on the Mac; reaches the box over mosh (interactive) / ssh (one-shot).
# Set QKVPS_DRYRUN=1 to print the interactive commands instead of running them.
set -uo pipefail

HOST="dev@quidkey-claude"
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LISTER="$DIR/../vps-claude-sessions.py"   # shipped alongside, in dotfiles/

# Run interactive commands, or print them under QKVPS_DRYRUN (for tests).
run() {
  if [ -n "${QKVPS_DRYRUN:-}" ]; then
    printf 'DRYRUN:'; printf ' %q' "$@"; printf '\n'
  else
    exec "$@"
  fi
}

usage() {
  cat <<'EOF'
qkvps — CLI for the Claude-on-VPS (quidkey-claude)

  qkvps [NAME]              attach — or create — tmux session NAME (default: claude)
  qkvps -l, --list          list tmux sessions on the box
  qkvps -k, --kill NAME     kill tmux session NAME
  qkvps -c, --clean [-f]    show orphaned mosh-servers   (-f / --force reaps them)
      --claude              list resumable Claude conversations (id · cwd · label)
  qkvps -r, --resume ID     resume a Claude conversation (ssh + cd its cwd + claude --resume)
  qkvps -h, --help          this help
      --json                machine-readable output (with --list / --claude)

Rule: if the first argument starts with '-' it is an action; otherwise it is a
session name. So `qkvps core` always attaches session "core".
EOF
}

attach() {  # $1 = session name
  run mosh "$HOST" -- tmux new -A -s "${1:-claude}"
}

list_sessions() {
  if [ -n "${JSON:-}" ]; then
    ssh "$HOST" 'tmux ls -F "#{session_name}|#{session_windows}|#{?session_attached,1,0}" 2>/dev/null' \
      | awk -F'|' 'BEGIN{printf "["} {printf "%s{\"name\":\"%s\",\"windows\":%s,\"attached\":%s}", (NR>1?",":""), $1, $2, ($3=="1"?"true":"false")} END{print "]"}'
  else
    ssh "$HOST" 'tmux ls 2>/dev/null || echo "(no tmux sessions running)"'
  fi
}

kill_session() {  # $1 = name
  local name="${1:-}"
  [ -n "$name" ] || { echo "qkvps: --kill needs a session name" >&2; return 2; }
  ssh "$HOST" "tmux kill-session -t $(printf %q "$name") 2>&1 && echo 'killed session: $name'"
}

clean_mosh() {  # $1 = force flag
  ssh "$HOST" 'echo "mosh-server processes (PID / uptime / RSS-KB):"; ps -o pid=,etime=,rss=,comm= -C mosh-server 2>/dev/null || echo "  none"'
  if [ -n "${1:-}" ]; then
    ssh "$HOST" 'pkill -x mosh-server && echo reaped || echo "nothing to reap"'
  else
    echo "Tip: 'qkvps --clean -f' reaps them (tmux/Claude sessions survive; reconnect with qkvps)."
  fi
}

list_claude() {
  if [ -n "${JSON:-}" ]; then
    ssh "$HOST" python3 - --json < "$LISTER"
  else
    ssh "$HOST" python3 - < "$LISTER"
  fi
}

resume_claude() {  # $1 = id (full or short prefix)
  local id="${1:-}" line full cwd rc
  [ -n "$id" ] || { echo "qkvps: --resume needs a conversation id" >&2; return 2; }
  line="$(ssh "$HOST" python3 - --resolve "$id" < "$LISTER" 2>&1)"; rc=$?
  if [ "$rc" -ne 0 ]; then echo "qkvps: $line" >&2; return 1; fi
  full="${line%%$'\t'*}"; cwd="${line#*$'\t'}"
  [ -n "$full" ] || { echo "qkvps: could not resolve '$id'" >&2; return 1; }
  echo "resuming ${full:0:8} in ${cwd:-<home>}"
  local -a t=(tmux new-session -A -s "claude-${full:0:8}")
  [ -n "$cwd" ] && t+=(-c "$cwd")
  t+=("claude --resume $full")
  run mosh "$HOST" -- "${t[@]}"
}

# ---- arg parse: flags = actions, bare word = session name --------------------
JSON=""; action=""; arg=""; force=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)     usage; exit 0 ;;
    --completion)  cat "$DIR/../completions/_qkvps"; exit 0 ;;
    --json)        JSON=1; shift ;;
    -l|--list)     action="list";   shift ;;
    -k|--kill)     action="kill";   arg="${2:-}"; shift; [ $# -gt 0 ] && shift ;;
    -c|--clean)    action="clean";  shift ;;
    -f|--force)    force=1;         shift ;;
    --claude)      action="claude"; shift ;;
    -r|--resume)   action="resume"; arg="${2:-}"; shift; [ $# -gt 0 ] && shift ;;
    --)            shift; break ;;
    -*)            echo "qkvps: unknown flag: $1" >&2; usage >&2; exit 2 ;;
    *)             action="${action:-attach}"; arg="$1"; shift ;;
  esac
done

case "${action:-attach}" in
  attach) attach "$arg" ;;
  list)   list_sessions ;;
  kill)   kill_session "$arg" ;;
  clean)  clean_mosh "$force" ;;
  claude) list_claude ;;
  resume) resume_claude "$arg" ;;
esac
