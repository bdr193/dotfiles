#!/usr/bin/env bash
# qkvps — the CLI for Rabea's Claude-on-VPS (quidkey-claude).
#
# Grammar (GNU-flag style, mirrors the `qk` CLI's conventions): a bare word is
# ALWAYS a tmux session to attach; every ACTION is a --flag. So `qkvps core`
# can only ever mean "attach session core" — no verb/name ambiguity.
#
# Short flags go to the read/navigate actions (--list/--claude/--resume); the
# state-changing ones (--kill/--clean) are long-only, so you type them out.
#
# Exception: --upload also gets a short -u — it's additive (no data loss), unlike
# kill/clean, and it's run constantly.
#
# Runs on the Mac; reaches the box over mosh (interactive) / ssh (one-shot).
# Set QKVPS_DRYRUN=1 to print the interactive commands instead of running them.
set -uo pipefail

HOST="dev@quidkey-claude"
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LISTER="$DIR/../vps-claude-sessions.py"   # shipped alongside, in dotfiles/

# Run interactive commands, or print them under QKVPS_DRYRUN (for tests).
run() {
  if [ -n "${QKVPS_DRYRUN:-}" ]; then
    printf 'DRYRUN:'; printf ' %q' "$@"; printf '\n'
  else
    exec "$@"
  fi
}

# Like run(), but does NOT exec — for multi-step actions (upload). Prints under DRYRUN.
runcmd() {
  if [ -n "${QKVPS_DRYRUN:-}" ]; then
    printf 'DRYRUN:'; printf ' %q' "$@"; printf '\n'
  else
    "$@"
  fi
}

# membership test: _in_list NEEDLE ITEM...   (avoids bash-4 associative arrays)
_in_list() { local x="$1"; shift; local e; for e in "$@"; do [ "$e" = "$x" ] && return 0; done; return 1; }

usage() {
  cat <<'EOF'
qkvps — CLI for the Claude-on-VPS (quidkey-claude)

  qkvps [NAME]              attach — or create — tmux session NAME (default: claude)
  qkvps -l, --list          list tmux sessions on the box
  qkvps -c, --claude        list resumable Claude conversations (id · cwd · label)
  qkvps -r, --resume ID     resume a Claude conversation (ssh + cd its cwd + claude --resume)
  qkvps     --kill NAME     kill tmux session NAME
  qkvps     --clean [-f]    show orphaned mosh-servers   (-f / --force reaps them)
  qkvps -u, --upload [F...] upload file(s) to the box; prints + copies the server path
                            (no arg = clipboard image, else newest Desktop screenshot)
  qkvps -h, --help          this help
      --json                machine-readable output (with --list / --claude)

Rule: if the first argument starts with '-' it is an action; otherwise it is a
session name. So `qkvps core` always attaches session "core". Short flags are the
read actions (-l/-c/-r); the state-changing ones (--kill/--clean) are long-only.
EOF
}

attach() {  # $1 = session name
  run mosh "$HOST" -- tmux new -A -s "${1:-claude}"
}

list_sessions() {
  if [ -n "${JSON:-}" ]; then
    ssh "$HOST" 'tmux ls -F "#{session_name}|#{session_windows}|#{?session_attached,1,0}" 2>/dev/null' \
      | awk -F'|' 'BEGIN{printf "["} {printf "%s{\"name\":\"%s\",\"windows\":%s,\"attached\":%s}", (NR>1?",":""), $1, $2, ($3=="1"?"true":"false")} END{print "]"}'
  else
    ssh "$HOST" 'tmux ls 2>/dev/null || echo "(no tmux sessions running)"'
  fi
}

kill_session() {  # $1 = name
  local name="${1:-}"
  [ -n "$name" ] || { echo "qkvps: --kill needs a session name" >&2; return 2; }
  ssh "$HOST" "tmux kill-session -t $(printf %q "$name") 2>&1 && echo 'killed session: $name'"
}

clean_mosh() {  # $1 = force flag
  ssh "$HOST" 'echo "mosh-server processes (PID / uptime / RSS-KB):"; ps -o pid=,etime=,rss=,comm= -C mosh-server 2>/dev/null || echo "  none"'
  if [ -n "${1:-}" ]; then
    ssh "$HOST" 'pkill -x mosh-server && echo reaped || echo "nothing to reap"'
  else
    echo "Tip: 'qkvps --clean -f' reaps them (tmux/Claude sessions survive; reconnect with qkvps)."
  fi
}

list_claude() {
  if [ -n "${JSON:-}" ]; then
    ssh "$HOST" python3 - --json < "$LISTER"
  else
    ssh "$HOST" python3 - < "$LISTER"
  fi
}

resume_claude() {  # $1 = id (full or short prefix)
  local id="${1:-}" line full cwd rc
  [ -n "$id" ] || { echo "qkvps: --resume needs a conversation id" >&2; return 2; }
  line="$(ssh "$HOST" python3 - --resolve "$id" < "$LISTER" 2>&1)"; rc=$?
  if [ "$rc" -ne 0 ]; then echo "qkvps: $line" >&2; return 1; fi
  full="${line%%$'\t'*}"; cwd="${line#*$'\t'}"
  [ -n "$full" ] || { echo "qkvps: could not resolve '$id'" >&2; return 1; }
  local session="claude-${full:0:8}"
  echo "resuming ${full:0:8} in ${cwd:-<home>}  (tmux session: $session)"
  # Set up the session over ssh first. A normal interactive tmux pane sources
  # ~/.zshrc (so `claude` is on PATH); a bare pane *command* would NOT be — that
  # made an earlier version exit instantly. So create the pane, then type the
  # resume command into it. Only on first create; re-running --resume reattaches.
  # Typing it as keys also means: if claude exits, you're left on a shell in cwd.
  if [ -z "${QKVPS_DRYRUN:-}" ]; then
    ssh "$HOST" bash -s -- "$session" "$cwd" "$full" <<'REMOTE'
sess=$1; dir=$2; full=$3
if ! tmux has-session -t "$sess" 2>/dev/null; then
  if [ -n "$dir" ]; then tmux new-session -d -s "$sess" -c "$dir"; else tmux new-session -d -s "$sess"; fi
  sleep 1   # let the pane shell finish sourcing ~/.zshrc before typing into it
  tmux send-keys -t "$sess" "claude --resume $full" Enter
fi
REMOTE
  fi
  run mosh "$HOST" -- tmux attach -t "$session"
}

upload() {  # "$@" = explicit file paths (no-arg auto-source added in Task 2)
  local -a srcs=("$@")
  local ts base safe remote_dir s
  local -a out=()

  if [ ${#srcs[@]} -eq 0 ]; then
    local ssdir newest
    # 1) clipboard image (needs pngpaste; reused temp file, no cleanup churn)
    if command -v pngpaste >/dev/null 2>&1; then
      local clipdir="${TMPDIR:-/tmp}/qkvps"; mkdir -p "$clipdir"
      pngpaste "$clipdir/clipboard.png" >/dev/null 2>&1 && srcs=("$clipdir/clipboard.png")
    fi
    # 2) newest screenshot
    if [ ${#srcs[@]} -eq 0 ]; then
      if [ -n "${QKVPS_SCREENSHOT_DIR:-}" ]; then
        ssdir="$QKVPS_SCREENSHOT_DIR"
      else
        ssdir="$(defaults read com.apple.screencapture location 2>/dev/null)"
        ssdir="${ssdir/#\~/$HOME}"; [ -d "$ssdir" ] || ssdir="$HOME/Desktop"
      fi
      newest="$(ls -t "$ssdir"/Screenshot* 2>/dev/null | head -1)"
      [ -n "$newest" ] && srcs=("$newest")
    fi
    # 3) nothing found
    if [ ${#srcs[@]} -eq 0 ]; then
      local hint=""; command -v pngpaste >/dev/null 2>&1 || hint=" (install pngpaste for clipboard images)"
      echo "qkvps: nothing to upload — no path, no clipboard image, no recent screenshot${hint}" >&2
      return 2
    fi
  fi

  for s in "${srcs[@]}"; do
    [ -e "$s" ] || { echo "qkvps: no such file: $s" >&2; return 2; }
    [ -d "$s" ] && { echo "qkvps: '$s' is a directory (not supported)" >&2; return 2; }
  done

  ts="${QKVPS_NOW:-$(date +%Y%m%d-%H%M%S)}"

  # ensure the box dir exists and learn its absolute path (one round-trip)
  if [ -n "${QKVPS_DRYRUN:-}" ]; then
    printf 'DRYRUN:'; printf ' %q' ssh "$HOST" 'mkdir -p ~/uploads && cd ~/uploads && pwd'; printf '\n'
    remote_dir="/home/dev/uploads"
  else
    remote_dir="$(ssh "$HOST" 'mkdir -p ~/uploads && cd ~/uploads && pwd')" \
      || { echo "qkvps: could not prepare ~/uploads on $HOST" >&2; return 1; }
  fi

  case "$remote_dir" in
    /*) ;;
    *)  echo "qkvps: unexpected upload dir from $HOST: '$remote_dir'" >&2; return 1 ;;
  esac

  local -a used=()
  local stem ext cand n
  for s in "${srcs[@]}"; do
    base="$(basename -- "$s")"
    safe="$(printf '%s' "$base" | tr -cs 'A-Za-z0-9._-' '-')"   # spaces/odd chars -> '-'
    # split extension so a disambiguating index lands before it (foo.png -> foo-2.png)
    # only the final suffix counts as the extension (a.tar.gz -> a.tar-2.gz on collision)
    case "$safe" in
      ?*.*) stem="${safe%.*}"; ext=".${safe##*.}" ;;
      *)    stem="$safe";      ext="" ;;
    esac
    cand="${ts}-${stem}${ext}"; n=1
    # two same-basename sources in one batch would collide on the box; make unique
    while _in_list "$cand" ${used[@]+"${used[@]}"}; do
      n=$((n+1)); cand="${ts}-${stem}-${n}${ext}"
    done
    used+=("$cand")
    runcmd scp -q "$s" "$HOST:$remote_dir/$cand" \
      || { echo "qkvps: scp failed for $s" >&2; return 1; }
    out+=("$remote_dir/$cand")
  done

  # NOTE: under QKVPS_DRYRUN the "DRYRUN:" echoes above also land on stdout;
  # only in a real run is stdout exactly the server path(s).
  printf '%s\n' "${out[@]}"                       # stdout = the server path(s)
  # clipboard: path(s) joined by newlines but with NO trailing newline, so pasting
  # a single path into the Claude pane doesn't auto-submit before you add context.
  local clip; clip="$(printf '%s\n' "${out[@]}")"   # $(...) strips trailing newline(s)
  if printf '%s' "$clip" | runcmd pbcopy 2>/dev/null; then
    echo "qkvps: uploaded ${#out[@]} file(s) -> path copied to clipboard" >&2
  else
    echo "qkvps: uploaded ${#out[@]} file(s) (clipboard copy unavailable)" >&2
  fi
}

# ---- arg parse: flags = actions, bare word = session name --------------------
JSON=""; action=""; arg=""; force=""; upload_files=()
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)     usage; exit 0 ;;
    --completion)  cat "$DIR/../completions/_qkvps"; exit 0 ;;
    --json)        JSON=1; shift ;;
    -l|--list)     action="list";   shift ;;
    -c|--claude)   action="claude"; shift ;;
    -r|--resume)   action="resume"; arg="${2:-}"; shift; [ $# -gt 0 ] && shift ;;
    --kill)        action="kill";   arg="${2:-}"; shift; [ $# -gt 0 ] && shift ;;
    --clean)       action="clean";  shift ;;
    -u|--upload)   action="upload"; shift ;;
    -f|--force)    force=1;         shift ;;
    --)            shift; break ;;
    -*)            echo "qkvps: unknown flag: $1" >&2; usage >&2; exit 2 ;;
    *)             if [ "${action:-}" = upload ]; then
                     upload_files+=("$1")
                   else
                     action="${action:-attach}"; arg="$1"
                   fi
                   shift ;;
  esac
done

# args after `--` belong to --upload too (lets you upload names starting with '-')
if [ "${action:-}" = upload ] && [ $# -gt 0 ]; then upload_files+=("$@"); fi

case "${action:-attach}" in
  attach) attach "$arg" ;;
  list)   list_sessions ;;
  claude) list_claude ;;
  resume) resume_claude "$arg" ;;
  kill)   kill_session "$arg" ;;
  clean)  clean_mosh "$force" ;;
  upload) upload ${upload_files[@]+"${upload_files[@]}"} ;;
esac
