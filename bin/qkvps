#!/usr/bin/env bash
# qkvps — the CLI for Rabea's Claude-on-VPS (quidkey-claude).
#
# Grammar (GNU-flag style, mirrors the `qk` CLI's conventions): a bare word is
# ALWAYS a tmux session to attach; every ACTION is a --flag. So `qkvps core`
# can only ever mean "attach session core" — no verb/name ambiguity.
#
# Short flags go to the read/navigate actions (--list/--claude/--resume); the
# state-changing ones (--kill/--clean) are long-only, so you type them out.
#
# Exception: --upload also gets a short -u — it's additive (no data loss), unlike
# kill/clean, and it's run constantly.
#
# Runs on the Mac; reaches the box over mosh (interactive) / ssh (one-shot).
# Set QKVPS_DRYRUN=1 to print the interactive commands instead of running them.
set -uo pipefail

HOST="${QKVPS_HOST:-dev@quidkey-claude}"   # override for tests / a differently-named box
# Backing services qkvps brings up for dev (docker compose project "quidkey").
# Postgres is intentionally excluded: on the box 5432 is taken, so postgres runs
# separately as the core-pg container on :5433 and core's .env points there.
DEV_DEPS="meilisearch fake-transfermate fake-flinks"
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LISTER="$DIR/../vps-claude-sessions.py"   # shipped alongside, in dotfiles/

# Run interactive commands, or print them under QKVPS_DRYRUN (for tests).
run() {
  if [ -n "${QKVPS_DRYRUN:-}" ]; then
    printf 'DRYRUN:'; printf ' %q' "$@"; printf '\n'
  else
    exec "$@"
  fi
}

# Like run(), but does NOT exec — for multi-step actions (upload). Prints under DRYRUN.
runcmd() {
  if [ -n "${QKVPS_DRYRUN:-}" ]; then
    printf 'DRYRUN:'; printf ' %q' "$@"; printf '\n'
  else
    "$@"
  fi
}

# membership test: _in_list NEEDLE ITEM...   (avoids bash-4 associative arrays)
_in_list() { local x="$1"; shift; local e; for e in "$@"; do [ "$e" = "$x" ] && return 0; done; return 1; }

usage() {
  cat <<'EOF'
qkvps — CLI for the Claude-on-VPS (quidkey-claude)

  qkvps [NAME]              attach — or create — tmux session NAME (default: claude)
  qkvps     --up [SVC...]   bring up dev services (no arg = all: deps + core + console)
  qkvps     --down [SVC...] stop dev services (no arg = core + console; deps stay up)
  qkvps     --forward [SVC...] tunnel box service(s) to your Mac via ssh -L (no arg = console + core)
  qkvps     --logs [SVC...] stream core/console dev-server logs (no arg = both; Ctrl-C to stop)
  qkvps -l, --list          list tmux sessions on the box
  qkvps -c, --claude        list resumable Claude conversations (id · cwd · label)
  qkvps -r, --resume ID     resume a Claude conversation (ssh + cd its cwd + claude --resume)
  qkvps     --kill NAME     kill tmux session NAME
  qkvps     --clean [-f]    show orphaned mosh-servers   (-f / --force reaps them)
  qkvps -u, --upload [F...] upload file(s) to the box; prints + copies the server path
                            (no arg = clipboard image, else newest Desktop screenshot)
  qkvps -h, --help          this help
      --json                machine-readable output (with --list / --claude)

Services (--up/--down): core  console  deps  meili  fake-tm  fake-flinks
Forward (--forward):    console  core  meili  fake-tm  fake-flinks  (Mac-side ssh -L)
Logs (--logs):          core  console  (mirrored dev-server output; deps → docker logs -f)
--up/--down run locally when you're already on the box, else over ssh.

Rule: if the first argument starts with '-' it is an action; otherwise it is a
session name. So `qkvps core` always attaches session "core". Short flags are the
read actions (-l/-c/-r); the state-changing ones (--kill/--clean) are long-only.
EOF
}

attach() {  # $1 = session name
  run mosh "$HOST" -- tmux new -A -s "${1:-claude}"
}

list_sessions() {
  if [ -n "${JSON:-}" ]; then
    ssh "$HOST" 'tmux ls -F "#{session_name}|#{session_windows}|#{?session_attached,1,0}" 2>/dev/null' \
      | awk -F'|' 'BEGIN{printf "["} {printf "%s{\"name\":\"%s\",\"windows\":%s,\"attached\":%s}", (NR>1?",":""), $1, $2, ($3=="1"?"true":"false")} END{print "]"}'
  else
    ssh "$HOST" 'tmux ls 2>/dev/null || echo "(no tmux sessions running)"'
  fi
}

kill_session() {  # $1 = name
  local name="${1:-}"
  [ -n "$name" ] || { echo "qkvps: --kill needs a session name" >&2; return 2; }
  ssh "$HOST" "tmux kill-session -t $(printf %q "$name") 2>&1 && echo 'killed session: $name'"
}

clean_mosh() {  # $1 = force flag
  ssh "$HOST" 'echo "mosh-server processes (PID / uptime / RSS-KB):"; ps -o pid=,etime=,rss=,comm= -C mosh-server 2>/dev/null || echo "  none"'
  if [ -n "${1:-}" ]; then
    ssh "$HOST" 'pkill -x mosh-server && echo reaped || echo "nothing to reap"'
  else
    echo "Tip: 'qkvps --clean -f' reaps them (tmux/Claude sessions survive; reconnect with qkvps)."
  fi
}

# ---- dev stack: backing services + core/console dev servers ------------------
# `--up [SVC...]` brings dev services up (idempotent) and returns; it does NOT
# attach (use `qkvps stack`). No SVC = everything: deps + core + console. A SVC
# is `core`, `console`, `deps` (meili + fakes; see DEV_DEPS), or a single dep by
# alias (meili, fake-tm, fake-flinks); unknown names are rejected. Postgres is
# NOT managed here: it runs separately as core-pg on :5433. Works from your Mac
# (ssh) or on the box (local) via on_box().
#
# `pnpm --filter` (not `turbo run dev`) is deliberate: it dodges the fake-* port
# clashes and turbo's strict env-mode stripping OP_SERVICE_ACCOUNT_TOKEN. pnpm/op
# resolve because send-keys lands in an interactive pane that sources ~/.zshrc
# (docker/tmux only need the default PATH).

# True when this shell is running ON the box itself (not the Mac).
_is_box() { [ "$(hostname 2>/dev/null)" = "${HOST#*@}" ]; }

# Run SCRIPT on the box: locally when we ARE the box, else over ssh. DRYRUN-aware.
on_box() {  # $1 = script text
  if _is_box; then runcmd bash -c "$1"; else runcmd ssh "$HOST" "$1"; fi
}

# Split targets into app windows (apps[]) and docker services (dsvcs[]/all_deps).
# Assigns to the CALLER's locals via dynamic scope; callers declare them first.
_resolve_targets() {  # "$@" = targets
  apps=(); dsvcs=(); all_deps=""
  local t
  for t in "$@"; do
    case "$t" in
      core|console)                 apps+=("$t") ;;
      deps)                         all_deps=1 ;;
      meili|meilisearch)            dsvcs+=(meilisearch) ;;
      tm|fake-tm|fake-transfermate) dsvcs+=(fake-transfermate) ;;
      flinks|fake-flinks)           dsvcs+=(fake-flinks) ;;
      *) echo "qkvps: unknown service '$t' (want: core console deps meili fake-tm fake-flinks)" >&2; return 2 ;;
    esac
  done
}

up_stack() {  # "$@" = targets (default: all)
  local -a targets=("$@"); [ $# -eq 0 ] && targets=(deps core console)
  local -a apps dsvcs; local all_deps
  _resolve_targets ${targets[@]+"${targets[@]}"} || return 2

  local remote
  remote="$(cat <<'REMOTE'
set -uo pipefail
repo="$HOME/quidkey/services/quidkey-monorepo"
cd "$repo" || { echo "qkvps: no monorepo at $repo" >&2; exit 1; }

ensure_win() {  # $1=window  $2=pnpm filter
  if ! tmux has-session -t stack 2>/dev/null; then
    tmux new-session -d -s stack -n "$1" -c "$repo"
  elif tmux list-windows -t stack -F '#{window_name}' | grep -qx "$1"; then
    echo "  $1: already running"; return
  else
    tmux new-window -t stack -n "$1" -c "$repo"
  fi
  sleep 1   # let the pane source ~/.zshrc so pnpm/op are on PATH
  tmux send-keys -t "stack:$1" 'OP_SERVICE_ACCOUNT_TOKEN=$(cat ~/.config/op/token) pnpm --filter '"$2"' run dev' Enter
  echo "  $1: started"
}
REMOTE
)"
  if [ -n "$all_deps" ]; then
    remote+="
echo \"==> deps: $DEV_DEPS\"; docker compose -f docker-compose.deps.yml up -d $DEV_DEPS || exit 1"
  elif [ "${#dsvcs[@]}" -gt 0 ]; then
    remote+="
echo \"==> deps: ${dsvcs[*]}\"; docker compose -f docker-compose.deps.yml up -d ${dsvcs[*]} || exit 1"
  fi
  local a filter
  for a in ${apps[@]+"${apps[@]}"}; do
    case "$a" in core) filter=quidkey-core ;; console) filter=quidkey-console ;; esac
    remote+="
ensure_win $a $filter"
  done
  remote+="
echo; echo \"up: [${targets[*]}]   attach: qkvps stack\""

  on_box "$remote"
}

down_stack() {  # "$@" = targets (default: whole app stack; deps left running)
  if [ $# -eq 0 ]; then
    on_box 'tmux kill-session -t stack 2>/dev/null && echo "stack: stopped (core + console). Docker deps left running." || echo "stack: not running (nothing to stop)."'
    return
  fi
  local -a apps dsvcs; local all_deps
  _resolve_targets "$@" || return 2

  local remote='cd "$HOME/quidkey/services/quidkey-monorepo" || exit 1'
  local a
  for a in ${apps[@]+"${apps[@]}"}; do
    remote+="
tmux kill-window -t stack:$a 2>/dev/null && echo \"  $a: stopped\" || echo \"  $a: not running\""
  done
  if [ -n "$all_deps" ]; then
    remote+="
echo \"==> stopping deps: $DEV_DEPS\"; docker compose -f docker-compose.deps.yml stop $DEV_DEPS"
  elif [ "${#dsvcs[@]}" -gt 0 ]; then
    remote+="
echo \"==> stopping deps: ${dsvcs[*]}\"; docker compose -f docker-compose.deps.yml stop ${dsvcs[*]}"
  fi
  on_box "$remote"
}

# `--forward [SVC…]`: open ssh -L tunnels so box services are reachable at
# localhost:<port> on your Mac — keeps the localhost origin the apps expect
# (console's CORS/cookies/redirects), unlike hitting quidkey-claude:<port> over
# Tailscale. Mac-side only; foreground (Ctrl-C to stop). No arg = console + core.
forward_stack() {  # "$@" = services (default: console core)
  if _is_box; then
    echo "qkvps --forward: you're already on the box — its services are local (console :3000, core :5679, meili :7700, fakes :8081/:8082). Run this from your Mac." >&2
    return 2
  fi
  local -a svcs=("$@"); [ $# -eq 0 ] && svcs=(console core)
  local -a lflags=() urls=(); local s port
  for s in "${svcs[@]}"; do
    case "$s" in
      console)                      port=3000 ;;
      core)                         port=5679 ;;
      meili|meilisearch)            port=7700 ;;
      tm|fake-tm|fake-transfermate) port=8081 ;;
      flinks|fake-flinks)           port=8082 ;;
      *) echo "qkvps --forward: unknown service '$s' (want: console core meili fake-tm fake-flinks)" >&2; return 2 ;;
    esac
    lflags+=(-L "${port}:localhost:${port}")
    urls+=("http://localhost:${port}  ($s)")
  done
  echo "forwarding to your Mac (Ctrl-C to stop):"
  printf '  %s\n' "${urls[@]}"
  run ssh -N "${lflags[@]}" "$HOST"
}

# `--logs [SVC…]`: stream core/console dev-server output to your terminal
# (read-only; foreground, Ctrl-C to stop). No arg = both, interleaved. Lazily
# mirrors each pane to ~/.qkvps/logs/<svc>.log via tmux pipe-pane (so it works on
# already-running servers, no restart) after seeding recent scrollback, then
# tail -F. Host-aware (local on the box, else ssh -t). Deps log to Docker.
logs_stack() {  # "$@" = services (default: core console)
  local -a svcs=("$@"); [ $# -eq 0 ] && svcs=(core console)
  local s
  for s in "${svcs[@]}"; do
    case "$s" in
      core|console) ;;
      *) echo "qkvps --logs: only core/console have file logs (deps → docker logs -f). Got '$s'." >&2; return 2 ;;
    esac
  done
  local script='set -u
export TERM=xterm-256color   # we ssh -t, forwarding the client TERM. Ghostty
                             # (xterm-ghostty) and other exotic TERMs are absent
                             # from the box terminfo, which makes EVERY tmux call
                             # below fail (missing/unsuitable terminal) and the
                             # window guard wrongly report no core window. NOTE:
                             # no apostrophes here -- script is bash single-quoted.
dir="$HOME/.qkvps/logs"; mkdir -p "$dir"
set --   # collect log paths as positional params: "$@" splits correctly under
         # the box shell (zsh), where unquoted $var is NOT word-split like bash.
for s in '"${svcs[*]}"'; do
  if ! tmux has-session -t stack 2>/dev/null || ! tmux list-windows -t stack -F "#{window_name}" | grep -qx "$s"; then
    echo "qkvps --logs: no \"$s\" window in the stack session; run: qkvps --up $s" >&2; exit 1
  fi
  if [ "$(tmux display -p -t "stack:$s" "#{pane_pipe}" 2>/dev/null)" != "1" ]; then
    tmux capture-pane -p -t "stack:$s" -S -500 >> "$dir/$s.log" 2>/dev/null || :
    tmux pipe-pane -t "stack:$s" "cat >> $dir/$s.log"
  fi
  set -- "$@" "$dir/$s.log"
done
echo "tailing $*  (Ctrl-C to stop)"
exec tail -n 200 -F "$@"'
  if _is_box; then
    run bash -c "$script"
  else
    run ssh -t "$HOST" "$script"
  fi
}

list_claude() {
  if [ -n "${JSON:-}" ]; then
    ssh "$HOST" python3 - --json < "$LISTER"
  else
    ssh "$HOST" python3 - < "$LISTER"
  fi
}

resume_claude() {  # $1 = id (full or short prefix)
  local id="${1:-}" line full cwd rc
  [ -n "$id" ] || { echo "qkvps: --resume needs a conversation id" >&2; return 2; }
  line="$(ssh "$HOST" python3 - --resolve "$id" < "$LISTER" 2>&1)"; rc=$?
  if [ "$rc" -ne 0 ]; then echo "qkvps: $line" >&2; return 1; fi
  full="${line%%$'\t'*}"; cwd="${line#*$'\t'}"
  [ -n "$full" ] || { echo "qkvps: could not resolve '$id'" >&2; return 1; }
  local session="claude-${full:0:8}"
  echo "resuming ${full:0:8} in ${cwd:-<home>}  (tmux session: $session)"
  # Set up the session over ssh first. A normal interactive tmux pane sources
  # ~/.zshrc (so `claude` is on PATH); a bare pane *command* would NOT be — that
  # made an earlier version exit instantly. So create the pane, then type the
  # resume command into it. Only on first create; re-running --resume reattaches.
  # Typing it as keys also means: if claude exits, you're left on a shell in cwd.
  if [ -z "${QKVPS_DRYRUN:-}" ]; then
    ssh "$HOST" bash -s -- "$session" "$cwd" "$full" <<'REMOTE'
sess=$1; dir=$2; full=$3
if ! tmux has-session -t "$sess" 2>/dev/null; then
  if [ -n "$dir" ]; then tmux new-session -d -s "$sess" -c "$dir"; else tmux new-session -d -s "$sess"; fi
  sleep 1   # let the pane shell finish sourcing ~/.zshrc before typing into it
  tmux send-keys -t "$sess" "claude --resume $full" Enter
fi
REMOTE
  fi
  run mosh "$HOST" -- tmux attach -t "$session"
}

upload() {  # "$@" = explicit file paths (no-arg auto-source added in Task 2)
  local -a srcs=("$@")
  local ts base safe remote_dir s
  local -a out=()

  if [ ${#srcs[@]} -eq 0 ]; then
    local ssdir newest
    # 1) clipboard image (needs pngpaste; reused temp file, no cleanup churn)
    if command -v pngpaste >/dev/null 2>&1; then
      local clipdir="${TMPDIR:-/tmp}/qkvps"; mkdir -p "$clipdir"
      pngpaste "$clipdir/clipboard.png" >/dev/null 2>&1 && srcs=("$clipdir/clipboard.png")
    fi
    # 2) newest screenshot
    if [ ${#srcs[@]} -eq 0 ]; then
      if [ -n "${QKVPS_SCREENSHOT_DIR:-}" ]; then
        ssdir="$QKVPS_SCREENSHOT_DIR"
      else
        ssdir="$(defaults read com.apple.screencapture location 2>/dev/null)"
        ssdir="${ssdir/#\~/$HOME}"; [ -d "$ssdir" ] || ssdir="$HOME/Desktop"
      fi
      newest="$(ls -t "$ssdir"/Screenshot* 2>/dev/null | head -1)"
      [ -n "$newest" ] && srcs=("$newest")
    fi
    # 3) nothing found
    if [ ${#srcs[@]} -eq 0 ]; then
      local hint=""; command -v pngpaste >/dev/null 2>&1 || hint=" (install pngpaste for clipboard images)"
      echo "qkvps: nothing to upload — no path, no clipboard image, no recent screenshot${hint}" >&2
      return 2
    fi
  fi

  for s in "${srcs[@]}"; do
    [ -e "$s" ] || { echo "qkvps: no such file: $s" >&2; return 2; }
    [ -d "$s" ] && { echo "qkvps: '$s' is a directory (not supported)" >&2; return 2; }
  done

  ts="${QKVPS_NOW:-$(date +%Y%m%d-%H%M%S)}"

  # ensure the box dir exists and learn its absolute path (one round-trip)
  if [ -n "${QKVPS_DRYRUN:-}" ]; then
    printf 'DRYRUN:'; printf ' %q' ssh "$HOST" 'mkdir -p ~/uploads && cd ~/uploads && pwd'; printf '\n'
    remote_dir="/home/dev/uploads"
  else
    remote_dir="$(ssh "$HOST" 'mkdir -p ~/uploads && cd ~/uploads && pwd')" \
      || { echo "qkvps: could not prepare ~/uploads on $HOST" >&2; return 1; }
  fi

  case "$remote_dir" in
    /*) ;;
    *)  echo "qkvps: unexpected upload dir from $HOST: '$remote_dir'" >&2; return 1 ;;
  esac

  local -a used=()
  local stem ext cand n
  for s in "${srcs[@]}"; do
    base="$(basename -- "$s")"
    safe="$(printf '%s' "$base" | tr -cs 'A-Za-z0-9._-' '-')"   # spaces/odd chars -> '-'
    # split extension so a disambiguating index lands before it (foo.png -> foo-2.png)
    # only the final suffix counts as the extension (a.tar.gz -> a.tar-2.gz on collision)
    case "$safe" in
      ?*.*) stem="${safe%.*}"; ext=".${safe##*.}" ;;
      *)    stem="$safe";      ext="" ;;
    esac
    cand="${ts}-${stem}${ext}"; n=1
    # two same-basename sources in one batch would collide on the box; make unique
    while _in_list "$cand" ${used[@]+"${used[@]}"}; do
      n=$((n+1)); cand="${ts}-${stem}-${n}${ext}"
    done
    used+=("$cand")
    runcmd scp -q "$s" "$HOST:$remote_dir/$cand" \
      || { echo "qkvps: scp failed for $s" >&2; return 1; }
    out+=("$remote_dir/$cand")
  done

  # NOTE: under QKVPS_DRYRUN the "DRYRUN:" echoes above also land on stdout;
  # only in a real run is stdout exactly the server path(s).
  printf '%s\n' "${out[@]}"                       # stdout = the server path(s)
  # clipboard: path(s) joined by newlines but with NO trailing newline, so pasting
  # a single path into the Claude pane doesn't auto-submit before you add context.
  local clip; clip="$(printf '%s\n' "${out[@]}")"   # $(...) strips trailing newline(s)
  if printf '%s' "$clip" | runcmd pbcopy 2>/dev/null; then
    echo "qkvps: uploaded ${#out[@]} file(s) -> path copied to clipboard" >&2
  else
    echo "qkvps: uploaded ${#out[@]} file(s) (clipboard copy unavailable)" >&2
  fi
}

# ---- arg parse: flags = actions, bare word = session name --------------------
JSON=""; action=""; arg=""; force=""; upload_files=(); targets=()
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)     usage; exit 0 ;;
    --completion)  cat "$DIR/../completions/_qkvps"; exit 0 ;;
    --json)        JSON=1; shift ;;
    -l|--list)     action="list";   shift ;;
    -c|--claude)   action="claude"; shift ;;
    -r|--resume)   action="resume"; arg="${2:-}"; shift; [ $# -gt 0 ] && shift ;;
    --kill)        action="kill";   arg="${2:-}"; shift; [ $# -gt 0 ] && shift ;;
    --clean)       action="clean";  shift ;;
    --up)          action="up";     shift ;;
    --down)        action="down";   shift ;;
    --forward)     action="forward"; shift ;;
    --logs)        action="logs";    shift ;;
    -u|--upload)   action="upload"; shift ;;
    -f|--force)    force=1;         shift ;;
    --)            shift; break ;;
    -*)            echo "qkvps: unknown flag: $1" >&2; usage >&2; exit 2 ;;
    *)             case "${action:-}" in
                     upload)   upload_files+=("$1") ;;
                     up|down|forward|logs)  targets+=("$1") ;;
                     *)        action="${action:-attach}"; arg="$1" ;;
                   esac
                   shift ;;
  esac
done

# args after `--` belong to --upload too (lets you upload names starting with '-')
if [ "${action:-}" = upload ] && [ $# -gt 0 ]; then upload_files+=("$@"); fi

case "${action:-attach}" in
  attach) attach "$arg" ;;
  list)   list_sessions ;;
  claude) list_claude ;;
  resume) resume_claude "$arg" ;;
  kill)   kill_session "$arg" ;;
  clean)  clean_mosh "$force" ;;
  up)     up_stack   ${targets[@]+"${targets[@]}"} ;;
  down)   down_stack ${targets[@]+"${targets[@]}"} ;;
  forward) forward_stack ${targets[@]+"${targets[@]}"} ;;
  logs)   logs_stack ${targets[@]+"${targets[@]}"} ;;
  upload) upload ${upload_files[@]+"${upload_files[@]}"} ;;
esac
