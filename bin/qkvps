#!/usr/bin/env bash
# qkvps has moved to its own repo (github.com/bdr193/qkvps, private).
# This shim keeps stale PATH entries working. Install the real CLI with:
#   git clone git@github.com:bdr193/qkvps.git ~/code/bdr193/qkvps
#   ~/code/bdr193/qkvps/install.sh
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/qkvps"
for cand in "$HOME/code/bdr193/qkvps/bin/qkvps" "$HOME/.local/bin/qkvps"; do
  if [ -x "$cand" ] && [ "$cand" != "$HERE" ]; then
    exec "$cand" "$@"
  fi
done
echo "qkvps moved to github.com/bdr193/qkvps: clone it and run install.sh" >&2
exit 1
